# ─── Broker QA Testing Credentials ───────────────────────────────────────────
# Used by Jest broker-qa tests for automated broker API testing.
# Copy to .env.broker and fill in your values. This file is gitignored.
#
# Legend:
#   STATIC  = fill once, rarely changes
#   DYNAMIC = generated fresh each session (from broker portal)
#   TOTP    = 32-char base32 seed — tests generate 6-digit code at runtime
#   SMS     = human provides OTP from phone (not automated)

# ─── AlphaQuark API Auth (STATIC) ───────────────────────────────────────────
AQ_API_KEY=
AQ_API_SECRET=
AQ_TEST_EMAIL=
AQ_ADVISOR_SUBDOMAIN=alphaquark

# ─── Zerodha (100% automated — TOTP) ────────────────────────────────────────
ZERODHA_EMAIL=
ZERODHA_PHONE=
ZERODHA_USER_ID=
ZERODHA_PASSWORD=
ZERODHA_TOTP_SECRET=
ZERODHA_API_KEY=           # DYNAMIC — from developers.kite.trade
ZERODHA_API_SECRET=        # DYNAMIC
ZERODHA_ACCESS_TOKEN=      # DYNAMIC — obtained after OAuth
ZERODHA_TPIN=

# ─── Angel One (100% automated — TOTP) ──────────────────────────────────────
ANGELONE_EMAIL=
ANGELONE_PHONE=
ANGELONE_CLIENT_ID=
ANGELONE_PASSWORD=
ANGELONE_TOTP_SECRET=
ANGELONE_API_KEY=          # DYNAMIC — from smartapi.angelbroking.com

